{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "jobTitle": { "type": "string" },
        "experience": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "resumeText": { "type": "string" },
        "resumeData": { "type": "object" },
        "targetRole": { "type": "string" },
        "targetIndustry": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "InterviewSession": {
      "title": "Interview Session",
      "description": "Stores metadata and analysis for an interview session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "overallScore": { "type": "number" },
        "summary": { "type": "string" },
        "analysis": { "type": "object" },
        "questions": { "type": "array", "items": { "type": "string" } },
        "metrics": { "type": "object" },
        "responseTime": { "type": "number" },
        "videoRef": { "type": "string", "description": "Reference to local IndexedDB video ID" }
      },
      "required": ["id", "uid", "date"]
    },
    "PracticeSession": {
      "title": "Practice Session",
      "description": "Stores metadata and analysis for a practice session.",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "uid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "score": { "type": "number" },
        "feedback": { "type": "string" },
        "mode": { "type": "string" },
        "promptText": { "type": "string" }
      },
      "required": ["sessionId", "uid", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/sessions/{sessionId}": {
      "schema": "InterviewSession",
      "description": "Interview session data."
    },
    "/practice_sessions/{sessionId}": {
      "schema": "PracticeSession",
      "description": "Practice session data."
    },
    "/test/connection": {
      "schema": "object",
      "description": "Used for initial connection testing."
    }
  }
}
