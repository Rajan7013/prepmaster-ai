rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (optional)
    //   - email: string (required)
    //   - resumeText: string (optional)
    //   - resumeData: map (optional)
    //   - targetIndustry: string (optional)
    //   - targetRole: string (optional)
    //   - createdAt: timestamp (optional)
    //
    // Collection: sessions
    // Document ID: {sessionId}
    // Fields:
    //   - sessionId: string (required)
    //   - uid: string (required)
    //   - timestamp: timestamp (required)
    //   - role: string (optional)
    //   - questions: list (optional)
    //   - overallScore: number (optional)
    //   - metrics: map (optional)
    //   - videoUrl: string (optional)
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "rajanprasaila@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 256;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['sessionId', 'uid', 'timestamp']) &&
             data.sessionId is string &&
             data.uid is string &&
             (data.timestamp is timestamp || data.timestamp == request.time);
    }

    // User profiles
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if (isOwner(uid) && isValidUser(request.resource.data)) || isAdmin();

      // Sessions subcollection
      match /sessions/{sessionId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) && isValidSession(request.resource.data);
        allow update: if (isOwner(uid) && isValidSession(request.resource.data)) || isAdmin();
      }
    }
  }
}
